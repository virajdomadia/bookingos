PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking_os"

# Auth — refresh tokens are opaque random strings, so only JWT_SECRET is used
# (must be >= 32 chars).
JWT_SECRET=generate-with-openssl-rand-hex-32

# Super admin (tenant provisioning). Optional — if unset, the super admin panel
# is disabled (fails closed). Set to a long random secret to enable it.
SUPER_ADMIN_SECRET=generate-with-openssl-rand-hex-32

# Refresh-cookie cross-site behaviour.
#   - Same registrable domain for web + API (incl. localhost ports): leave as
#     "strict".
#   - Different domains (e.g. *.vercel.app web + *.railway.app API): set to
#     "none" so the browser sends the cookie cross-site (forces Secure).
COOKIE_SAMESITE=strict
# Optional: scope the refresh cookie to a parent domain shared by web + API
# (e.g. ".example.com"). Leave unset for localhost.
# COOKIE_DOMAIN=

# Email
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="BookingOS <onboarding@resend.dev>"

# Frontend CORS
FRONTEND_URL=http://localhost:3000
ROOT_DOMAIN=localhost
