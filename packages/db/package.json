{
  "name": "@booking-os/db",
  "version": "1.0.0",
  "description": "Prisma database schema and migrations",
  "private": true,
  "scripts": {
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "node --loader ts-node/esm scripts/seed.ts",
    "generate": "prisma generate",
    "rls": "psql \"$DATABASE_URL\" -f scripts/setup-rls.sql",
    "deploy": "prisma migrate deploy && pnpm run rls"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "prisma": "^5.8.0",
    "ts-node": "^10.9.2"
  }
}
