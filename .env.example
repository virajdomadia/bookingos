# API Configuration
API_PORT=4000
API_HOST=localhost
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking_os"

# Auth Secret (generate with: openssl rand -hex 32). Refresh tokens are opaque
# random strings, so only this access-token secret is used.
JWT_SECRET=your-jwt-secret-here-32-characters-minimum

# Refresh-cookie cross-site behaviour: "strict" when web + API share a
# registrable domain (incl. localhost ports); "none" when they're on different
# domains (e.g. Vercel + Railway) so the cookie is sent cross-site.
COOKIE_SAMESITE=strict
# COOKIE_DOMAIN=.example.com

# Super admin panel secret — sent as the X-Super-Admin-Secret header to
# /superadmin/* routes (the only path that creates tenants). Generate with:
# openssl rand -hex 32. Without it, the super admin routes return 503.
SUPER_ADMIN_SECRET=your-super-admin-secret-here-32-characters-minimum

# Email (Resend)
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM="BookingOS <onboarding@resend.dev>"

# Frontend
FRONTEND_URL=http://localhost:3000
ROOT_DOMAIN=localhost

# Public API
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ROOT_DOMAIN=localhost
