# API Configuration
API_PORT=4000
API_HOST=localhost
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking_os"

# Auth Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here-32-characters-minimum
JWT_REFRESH_SECRET=your-refresh-secret-here-32-characters-minimum

# Email (Resend)
RESEND_API_KEY=your-resend-api-key-here

# Frontend
FRONTEND_URL=http://localhost:3000
ROOT_DOMAIN=localhost

# Public API
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ROOT_DOMAIN=localhost
